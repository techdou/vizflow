# ====== Secrets (NEVER commit) ======
.env
.env.local
.env.*.local
*.key
*.pem
backend/.env
backend/.env.local

# ====== Python ======
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
backend/data/*.pyc
backend/src/**/__pycache__/

# ====== Node / Vite / React ======
node_modules/
frontend/dist/
frontend/.vite/
frontend/build/
.vite/
*.local
.pnpm-store/

# ====== Backend runtime data (regenerated on first run) ======
backend/data/db.sqlite3
backend/data/db.sqlite3-*
backend/data/thumbnails/
backend/data/datasets/
backend/logs/
*.log
*.sqlite3
*.sqlite

# ====== Thumbnail cache (regenerated by background task) ======
data/thumbnails/*
!data/thumbnails/.gitkeep

# ====== IDE / OS ======
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ====== Generated reports (实验报告本身,不进代码仓库) ======
report/
!report/.gitkeep
